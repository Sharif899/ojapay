# ── DATABASE (Railway PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/ojapay"

# ── NEXTAUTH ───────────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://ojapay.xyz"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ── EMAIL (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="OjaPay <noreply@ojapay.xyz>"

# ── BLOCKCHAIN (Alchemy - Base) ────────────────────────────────────────────────
NEXT_PUBLIC_ALCHEMY_ID="your-alchemy-api-key"
NEXT_PUBLIC_WALLET_CONNECT_ID="your-walletconnect-project-id"

# ── BASE NETWORK ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_CHAIN_ID="8453"
NEXT_PUBLIC_USDC_CONTRACT_BASE="0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913"

# ── APP ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://ojapay.xyz"
WEBHOOK_SECRET="generate-with: openssl rand -hex 32"
